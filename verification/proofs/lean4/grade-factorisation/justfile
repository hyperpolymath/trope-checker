# Grade-factorisation Lean harness (tropical factorisation probe). Run from this dir.
# Imports the grade-boundary carrier; reuses its pinned Lean 4 v4.16.0 + Mathlib build
# (shared via .lake/packages). Do NOT modify grade-boundary.
set shell := ["bash", "-uc"]

# Build the development (the green half = the homomorphism; the breaker theorems are
# verified failures of the faithful candidate).
build *args:
    lake build {{args}}

# Falsify: the anti-test. A proof is only worth its axioms. Fails the run if the
# development smuggles a forbidden tactic/axiom, is not sorry-free, stops building, or
# loses either falsifier witness (D6a the candidate breaker, D6b the trivial-map foil).
falsify:
    @echo "[falsify] no forbidden tactics/axioms in source…"
    @! grep -nE '(:=|by|;|<;>|=>|\|)[[:space:]]*(sorry|admit)\b|\bnative_decide\b' GradeFactorisation.lean || (echo "FAIL: forbidden tactic" && exit 1)
    @! grep -nE '^[[:space:]]*axiom\b' GradeFactorisation.lean || (echo "FAIL: user axiom declared" && exit 1)
    @echo "[falsify] build is green…"
    lake build
    @echo "[falsify] axiom audit contains no sorryAx…"
    @if lake build 2>&1 | grep -E "depends on axioms|does not depend" | tee /dev/stderr | grep -q "sorryAx"; then echo "FAIL: sorryAx present" && exit 1; fi
    @echo "[falsify] D6a — the faithful-candidate breaker is a verified theorem (piV_not_hom)…"
    @lake build 2>&1 | grep -q "'Trope.Factorisation.piV_not_hom' depends on axioms" || (echo "FAIL: D6a breaker missing" && exit 1)
    @lake build 2>&1 | grep -q "'Trope.Factorisation.phiV_not_hom' depends on axioms" || (echo "FAIL: D6a fate-level breaker missing" && exit 1)
    @echo "[falsify] D6b — the trivial map is a hom yet fails nontriviality (phi0_hom + phi0_not_nontrivial)…"
    @lake build 2>&1 | grep -q "'Trope.Factorisation.phi0_hom' depends on axioms" || (echo "FAIL: D6b trivial-hom missing" && exit 1)
    @lake build 2>&1 | grep -q "'Trope.Factorisation.phi0_not_nontrivial' depends on axioms" || (echo "FAIL: D6b nontriviality-foil missing" && exit 1)
    @echo "[falsify] D6c — homomorphism is exhaustive over every fate pairing (phi_hom by cases × cases)…"
    @echo "[falsify] PASS — sorry-free, axiom-clean, green; both falsifier witnesses live."

# Print the axiom dependencies of every deliverable theorem (expect propext/Quot.sound
# only — no sorryAx, no Classical.choice).
axioms:
    @lake build 2>&1 | grep -E "depends on axioms|does not depend"

# Surface the three-way verdict's load-bearing theorems by name.
verdict:
    @echo "Verdict (B) FACTORS but VERIDICALITY-BLIND — evidence:"
    @echo "  exists (factors)      : pi_hom, pi_one, piHom, pi_nontrivial"
    @echo "  not (A) (forced blind): forced_collapse, no_veridicality_faithful_hom"
    @echo "  not (C) (hom exists)  : pi_hom + pi_nontrivial"
    @echo "  D2 breaker (candidate): phiV_not_hom, piV_not_hom"
    @echo "  D5 complement (F2)    : pi_blind_to_noncomm, grade_F2_noncomm, pi_collapses_F2"

clean:
    lake clean
